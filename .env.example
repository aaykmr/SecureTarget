PORT=8080
# Relative paths are resolved from the monorepo root (same DB for Next + ingest)
SECURETARGET_DB_PATH=securetarget.sqlite
# SecureTarget-operated device identity DB (separate from customer attribution DB)
SECURETARGET_DEVICE_DB_PATH=securetarget-device.sqlite

# Same pepper for hashing API keys in dashboard + ingest (required for keys to work)
API_KEY_PEPPER=change-me-to-a-long-random-string-aayush

# Next.js dashboard (web/) — use either name (Auth.js also reads AUTH_SECRET)
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# AUTH_SECRET=same-as-above-if-you-prefer-authjs-name
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_INGEST_URL=http://localhost:8080
# Public URL of the Next.js dashboard (used in hosted /sdk.js copy-paste snippets)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Ingest CORS (browser SDK). Use a specific origin in production, e.g. https://app.customer.com
CORS_ORIGIN=*

# Ingest: require x-session-id on /v1/record (after clients use bootstrap)
# INGEST_REQUIRE_SESSION=1

# Ingest: log API key resolution diagnostics (never logs full key or pepper value)
# INGEST_DEBUG=1

# Dashboard: on "Generate API key", log pepperFingerprint (compare to ingest with INGEST_DEBUG=1)
# API_KEY_DEBUG=1

# --- Cashfree subscriptions (sandbox) — optional. When CASHFREE_CLIENT_ID + CASHFREE_CLIENT_SECRET are set,
# the account must have an ACTIVE (or BANK_APPROVAL_PENDING) subscription to generate API keys and view events.
# Ingest rejects API keys for users without an active subscription row. Configure the webhook URL in Cashfree:
#   {NEXT_PUBLIC_APP_URL}/api/webhooks/cashfree
# CASHFREE_CLIENT_ID=
# CASHFREE_CLIENT_SECRET=
# CASHFREE_ENV=sandbox
# Plan id from Cashfree Subscriptions (sandbox dashboard or POST /pg/plans)
# CASHFREE_PLAN_ID=
# Defaults to CASHFREE_CLIENT_SECRET if unset (Cashfree often uses the same secret for webhook HMAC).
# CASHFREE_WEBHOOK_SECRET=
# Customer phone sent on subscription create (sandbox placeholder is fine)
# CASHFREE_CUSTOMER_PHONE=9999999999
# Client must match sandbox vs production for Cashfree.js
# NEXT_PUBLIC_CASHFREE_ENV=sandbox
