PORT=8080

# --- Postgres (dashboard + ingest + device matching) ---
# Start local Postgres: npm run db:up
DATABASE_URL=postgres://securetarget:securetarget@localhost:5433/securetarget

# Redis (local Docker — no password). Production: redis://:PASSWORD@<data-ec2-private-ip>:6379
REDIS_URL=redis://localhost:6380

# JWT for dashboard SPA (register / login / me)
AUTH_SECRET=dev-auth-secret-change-in-production
JWT_SECRET=dev-auth-secret-change-in-production

# Dashboard SPA origin (CORS)
DASHBOARD_CORS_ORIGIN=http://localhost:3000

# SQLite fallback only when DATABASE_URL is unset (unit tests)
# SECURETARGET_DB_PATH=securetarget.sqlite
# SECURETARGET_DEVICE_DB_PATH=securetarget-device.sqlite

# Same pepper for hashing API keys in dashboard + ingest (required for keys to work)
API_KEY_PEPPER=change-me-to-a-long-random-string-aayush

# Vite dashboard (web/) — copy to web/.env for local dev
# VITE_API_URL=http://localhost:8080
# VITE_INGEST_URL=http://localhost:8080
# VITE_APP_URL=http://localhost:3000

# Ingest CORS (browser SDK). Use a specific origin in production, e.g. https://app.customer.com
CORS_ORIGIN=*

# Ingest: require x-session-id on /v1/record (after clients use bootstrap)
# INGEST_REQUIRE_SESSION=1

# Ingest: log API key resolution diagnostics (never logs full key or pepper value)
# INGEST_DEBUG=1

# --- Cashfree subscriptions (sandbox) — optional ---
# CASHFREE_CLIENT_ID=
# CASHFREE_CLIENT_SECRET=
# CASHFREE_ENV=sandbox
# CASHFREE_PLAN_ID=
# CASHFREE_WEBHOOK_SECRET=
# CASHFREE_CUSTOMER_PHONE=9999999999
