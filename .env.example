PORT=8080
# Relative paths are resolved from the monorepo root (same DB for Next + ingest)
SECURETARGET_DB_PATH=securetarget.sqlite

# Same pepper for hashing API keys in dashboard + ingest (required for keys to work)
API_KEY_PEPPER=change-me-to-a-long-random-string-aayush

# Next.js dashboard (web/) — use either name (Auth.js also reads AUTH_SECRET)
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# AUTH_SECRET=same-as-above-if-you-prefer-authjs-name
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_INGEST_URL=http://localhost:8080
# Public URL of the Next.js dashboard (used in hosted /sdk.js copy-paste snippets)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Ingest CORS (browser SDK). Use a specific origin in production, e.g. https://app.customer.com
CORS_ORIGIN=*

# Ingest: require x-session-id on /v1/record (after clients use bootstrap)
# INGEST_REQUIRE_SESSION=1

# Ingest: log API key resolution diagnostics (never logs full key or pepper value)
# INGEST_DEBUG=1

# Dashboard: on "Generate API key", log pepperFingerprint (compare to ingest with INGEST_DEBUG=1)
# API_KEY_DEBUG=1
