# Copy to .env.db on the database EC2 host (same directory as docker-compose.db.yml).
# Generate strong passwords: openssl rand -base64 32

POSTGRES_USER=securetarget
POSTGRES_PASSWORD=change-me-strong-postgres-password
POSTGRES_DB=securetarget
POSTGRES_PORT=5432

REDIS_PASSWORD=change-me-strong-redis-password
REDIS_PORT=6379
