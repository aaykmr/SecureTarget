{
  "name": "eventiqn",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "backend",
    "sdk/web",
    "web",
    "site"
  ],
  "scripts": {
    "test": "sh -c 'tsx --test backend/test/*.test.ts'",
    "test:pg": "npm run db:up && node scripts/wait-for-postgres.mjs && tsx --test backend/test/apiKeyResolvePg.test.ts",
    "db:up": "docker compose up -d --wait postgres redis",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d --wait postgres",
    "db:logs": "docker compose logs -f postgres",
    "dev:web": "npm run dev --workspace web",
    "dev:site": "npm run dev --workspace @eventiqn/site",
    "dev:backend": "npm run db:up && node scripts/wait-for-postgres.mjs && npm run start --workspace @eventiqn/backend",
    "dev:ingest": "npm run dev:backend",
    "build:sdk-browser": "npm run build:browser --workspace @eventiqn/web-sdk",
    "build:sdk-zips": "node scripts/build-sdk-zips.mjs"
  },
  "devDependencies": {
    "tsx": "^4.20.6",
    "typescript": "^5.9.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
